# ====== Telegram Bot ======
# 从 @BotFather 新建的机器人 Token（与 Marzban 官方 Bot 不同！）
BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER

# 你的 Telegram 管理员数字 ID（逗号分隔多个）
ADMIN_IDS=YOUR_TELEGRAM_ID

# ====== 数据库 ======
# SQLite（推荐，简单无需额外安装）
DB_URL=CHANGE_ME

# ====== Marzban 面板 ======
# 你的面板地址（末尾不加斜杠）
MARZBAN_HOST=https://your-panel-domain.com
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=YOUR_PASSWORD_HERE


CRYPTOMUS_MERCHANT_ID=YOUR_MERCHANT_ID
CRYPTOMUS_API_KEY=YOUR_API_KEY_HERE
